<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="changelog-create-table-role-permissions" author="Strigalev Andrey">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists schemaName="rbac_demo" tableName="role_permissions"/>
            </not>
        </preConditions>

        <createTable tableName="role_permissions"
                     schemaName="rbac_demo"
                     remarks="Таблица для хранения набора прав для каждой роли">

            <column name="role_id"
                    type="UUID"
                    remarks="id роли">
                <constraints nullable="false"/>
            </column>

            <column name="permission_id"
                    type="UUID"
                    remarks="id прав">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <addPrimaryKey schemaName="rbac_demo"
                       tableName="role_permissions"
                       columnNames="role_id, permission_id"
                       constraintName="pk_role_permissions"/>

        <createIndex schemaName="rbac_demo"
                     tableName="role_permissions"
                     indexName="idx_role_permissions_role_id">
            <column name="role_id"/>
        </createIndex>

        <createIndex schemaName="rbac_demo"
                     tableName="role_permissions"
                     indexName="idx_role_permissions_permission_id">
            <column name="permission_id"/>
        </createIndex>

        <addForeignKeyConstraint baseTableSchemaName="rbac_demo"
                                 baseTableName="role_permissions"
                                 baseColumnNames="role_id"
                                 constraintName="fk_role_permissions_role_id_roles_id"
                                 referencedTableSchemaName="rbac_demo"
                                 referencedTableName="roles"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableSchemaName="rbac_demo"
                                 baseTableName="role_permissions"
                                 baseColumnNames="permission_id"
                                 constraintName="fk_role_permissions_permission_id_permissions_id"
                                 referencedTableSchemaName="rbac_demo"
                                 referencedTableName="permissions"
                                 referencedColumnNames="id"/>

    </changeSet>

</databaseChangeLog>