<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="changelog-create-table-roles" author="Strigalev Andrey">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists schemaName="rbac_demo" tableName="roles"/>
                <indexExists schemaName="rbac_demo" tableName="roles" indexName="idx_roles_name"/>
            </not>
        </preConditions>

        <createTable tableName="roles"
                     schemaName="rbac_demo"
                     remarks="Таблица для хранения ролей">

            <column name="id"
                    type="UUID"
                    defaultValueComputed="gen_random_uuid()"
                    remarks="id роли">
                <constraints primaryKey="true"
                             nullable="false"/>
            </column>

            <column name="name"
                    type="VARCHAR(100)"
                    remarks="Название роли">
                <constraints nullable="false" unique="true"/>
            </column>

        </createTable>

        <createIndex schemaName="rbac_demo"
                     tableName="roles"
                     indexName="idx_roles_name"
                     unique="true">
            <column name="name"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>